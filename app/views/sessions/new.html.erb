<% content_for :title, "ユーザー登録" %>
<h1>ログイン画面</h1>
<%= render "shared/error_messages", object: @user %>
<%= form_with url: session_path, scope: :user, autocomplete: "off", data: { turbo: false } do |f| %>
   <div class="form-group">
    <%= f.label :email, "メールアドレス" %><br>
    <%= f.email_field :email, class: "form-control" %>
  </div>
   <div class="form-group">
    <%= f.label :password, "パスワード" %><br>
    <%= f.password_field :password, class: "form-control" %>
  </div>

  <div class="user-actions">
    <%= f.submit "ログイン", class: "btn move-btn" %>
    <%= link_to '戻る', request.referer || root_path, class: "btn"  %>
  </div>
<% end %>
