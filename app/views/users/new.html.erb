<% content_for :title, "ユーザー登録" %>
<h1>新規ユーザー登録</h1>
<%= render "shared/error_messages", object: @user %>
<%= form_with model: @user, local: true, autocomplete: "off", data: { turbo: false } do |form| %>

  <div class="form-group">
    <%= form.label :user_name, "ユーザー名" %><br>
    <%= form.text_field :user_name, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= form.label :email, "メールアドレス" %><br>
    <%= form.email_field :email, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= form.label :password, "パスワード" %><br>
    <%= form.password_field :password, class: "form-control" %>
  </div>
  <div class="user-actions">
    <%= form.submit "登録", class: "btn edit-btn" %>
  </div>
<% end %>
