<header>
  <%= link_to "トップ", root_path %>

  <% if current_user %>
    <span>ログイン中: <%= current_user.user_name %></span>
    <%= link_to "マイページ", user_path(current_user) %>
    <%= button_to "ログアウト", logout_path, method: :delete %>
  <% else %>
    <% unless current_page?(new_session_path) %>
      <%= link_to "ログイン", new_session_path %>
    <% end %>
    <% unless current_page?(new_user_path) %>
      <%= link_to "新規登録", new_user_path %>
    <% end %>
    <%= button_to "ゲストログイン", guest_login_path, method: :post %>
  <% end %>
</header>
