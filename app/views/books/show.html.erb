<% content_for :title, @book.title %>
<div>
  <p>書籍名：<%= @book.title %></p>
  <p>著者：<%= @book.author %></p>
  <p>シリーズ：<%= @book.series&.name || "単巻" %></p>
  <p>評価：<%= @book.rating %></p>
  <p>内容：<%= @book.body %></p>
  <% if @ownership.present? %>
    <p>ステータス：<%= @ownership.status ? @ownership.status_label : "未設定" %></p>
    <h3>タグ</h3>
    <% @ownership.book.tags.each do |tag| %>
      <span class="tag" ><%= tag.name %></span>
    <% end %>
  <% end %>
</div>
<div class="user-actions">
  <%= button_to "削除",
    book_path(@book),
    method: :delete,
    form: { data: { turbo: false } },
    data: { turbo_confirm: "本当に削除しますか？" }, class: "btn delete-btn" %>
  <%= link_to "編集", edit_book_path(@book), class: "btn edit-btn" %>
  <%= link_to '一つ前に戻る', request.referer || root_path, class: "btn move-btn"  %>
  <%= link_to '一覧に戻る', books_path, class: "btn move-btn" %>
</div>
