<h1>Books#index</h1>
<h2>検索フォーム</h2>
<div>
<%= form_with url: books_path, method: :get, local: true do |f| %>
  <%= f.label :keyword, "キーワード" %>
  <%= f.text_field :keyword %>
  <%= f.collection_select :tag_ids, Tag.all, :id, :name, include_blank: "タグ選択" %>
  <%= f.submit "検索" %>
<% end %></div>
<div class="books-list" >
  <% @books.each do |book| %>
    <%= link_to book_path(book), class: "book-card" do %>
      <%= book.title %>
    <% end %>
  <% end %>
</div>
<%= link_to "新規登録", new_book_path %>
